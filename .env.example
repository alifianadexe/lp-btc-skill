# Copy this file to .env and fill your values.
# PowerShell example: Copy-Item .env.example .env

# RPC endpoint (use your private provider URL)
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Comma-separated wallet addresses to track
WALLET_ADDRESSES=0xYourWallet1,0xYourWallet2

# Optional: comma-separated ERC20 token addresses for wallet spot balances
WALLET_TOKEN_ADDRESSES=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913,0xcbB7C0000aB88B473b1f5aFd9ef808440eed33Bf,0x4200000000000000000000000000000000000006

# Optional: output CSV path
LP_HISTORY_CSV=lp_history.csv
